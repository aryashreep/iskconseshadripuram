# ============================================
# ISKCON Temple Website — Environment Variables
# ============================================
#
# How to use:
#
# Option A — .env file (recommended for local dev):
#   1. Copy this file to .env:  cp .env.example .env
#   2. Edit .env with your actual values (e.g. Razorpay test keys)
#   3. vlucas/phpdotenv is already wired in via config.php — no setup needed
#
# Option B — Apache SetEnv (alternative without .env file):
#   Add to your .htaccess or Apache vhost config:
#     SetEnv RAZORPAY_KEY_ID "rzp_test_xxxxxxxxxxxx"
#
# Option C — System environment variables:
#   Set these in your OS environment and restart the web server.
#   On Laragon: Settings → Environment Variables
#
# ============================================
# Database Configuration
# ============================================
# MySQL/MariaDB host address
DB_HOST="localhost"

# Database name
DB_NAME="isjm_donations"

# Database username
DB_USER="root"

# Database password (leave blank if no password)
DB_PASS=""

# ============================================
# Razorpay Payment Gateway
# ============================================
# Razorpay API Key ID (get from https://dashboard.razorpay.com)
# Use test keys (rzp_test_*) for development, live keys (rzp_live_*) for production
RAZORPAY_KEY_ID="rzp_test_XXXXXXXXXXXXXXXX"

# Razorpay API Key Secret
RAZORPAY_KEY_SECRET="XXXXXXXXXXXXXXXXXXXXXXXX"

# Set to "true" for local development (shows test mode banner, safe for testing)
# Must be "false" or omitted on production
RAZORPAY_TEST_MODE="true"

# ============================================
# Site Configuration (optional overrides)
# ============================================
# These can override settings in config.php if needed
#
# SITE_NAME="ISKCON The Palace Temple of Lord Jagannath"
# SITE_EMAIL="info@iskconbangalore.co.in"
# SITE_PHONE="+91 99860 77269"
