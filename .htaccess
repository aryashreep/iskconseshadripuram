AddDefaultCharset UTF-8

# ============================================
# Security Headers
# ============================================
<IfModule mod_headers.c>

  # Prevent clickjacking
  Header always set X-Frame-Options "DENY"

  # Prevent MIME type sniffing
  Header always set X-Content-Type-Options "nosniff"

  # Control referrer information
  Header always set Referrer-Policy "strict-origin-when-cross-origin"

  # HTTP Strict Transport Security (1 year, includes subdomains, preload-ready)
  Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"

  # Restrict browser features
  Header always set Permissions-Policy "camera=(), microphone=(), geolocation=(), payment=(self), autoplay=()"

  # Content Security Policy (single line required by Apache)
  Header always set Content-Security-Policy "default-src 'self'; script-src 'self' https://cdn.jsdelivr.net https://checkout.razorpay.com https://cdn.razorpay.com https://cdnjs.cloudflare.com https://www.googletagmanager.com https://www.google-analytics.com https://cse.google.com http://cse.google.com https://www.google.com https://www.youtube.com https://youtube.com 'unsafe-inline' 'unsafe-eval'; style-src 'self' https://fonts.googleapis.com https://cdnjs.cloudflare.com https://cdn.jsdelivr.net https://cse.google.com https://www.google.com 'unsafe-inline'; font-src 'self' https://fonts.gstatic.com https://cdnjs.cloudflare.com data:; img-src 'self' https://picsum.photos data: https: http://clients1.google.com; connect-src 'self' https://api.razorpay.com https://cdn.jsdelivr.net https://wttr.in https://lumberjack.razorpay.com https://www.google-analytics.com https://analytics.google.com; frame-src 'self' https://checkout.razorpay.com https://api.razorpay.com https://maps.google.com https://www.google.com https://cse.google.com https://www.youtube.com https://youtube.com; form-action 'self'; base-uri 'self';

</IfModule>

# ============================================
# Prevent Directory Browsing
# ============================================
Options -Indexes

# ============================================
# URL Rewriting
# ============================================
<IfModule mod_rewrite.c>
RewriteEngine On

# Sitemap: /sitemap.xml → sitemap.php
RewriteRule ^sitemap\.xml$ sitemap.php [L]

# Yatra detail pages: /yatra/package-name → yatra/detail.php?slug=package-name
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME} !-f
RewriteRule ^yatra/panihati/?$ yatra/panihati.php [L]

RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME} !-f
RewriteRule ^yatra/([^/]+)/?$ yatra/detail.php?slug=$1 [L,QSA]

# Blogs detail pages: /blogs/blog-slug → blogs/detail.php?slug=blog-slug
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME} !-f
RewriteRule ^blogs/([^/]+)/?$ blogs/detail.php?slug=$1 [L,QSA]

# Donate static pages (must come before the cause-slug rule)
RewriteRule ^donate/payment-success/?$ donate/payment-success.php [L,QSA]
RewriteRule ^donate/payment-failed/?$ donate/payment-failed.php [L,QSA]

# Donate cause pages: /donate/cause-slug → donate/donate-seva.php?cause=cause-slug
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME} !-f
RewriteRule ^donate/([a-z0-9\-]+)/?$ donate/donate-seva.php?cause=$1 [L,QSA]

# Booking puja detail pages: /booking/puja/puja-slug → booking/puja/detail.php?slug=puja-slug
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME} !-f
RewriteRule ^booking/puja/([a-z0-9\-]+)/?$ booking/puja/detail.php?slug=$1 [L,QSA]

# Booking yagya detail pages: /booking/yagya/yagya-slug → booking/yagya/detail.php?slug=yagya-slug
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME} !-f
RewriteRule ^booking/yagya/([a-z0-9\-]+)/?$ booking/yagya/detail.php?slug=$1 [L,QSA]

# ============================================
# Sudamaseva Module — API Rewrites
# ============================================

# api/sudamaseva/create-subscription → api/sudamaseva-create-subscription.php
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME} !-f
RewriteRule ^api/sudamaseva/create-subscription/?$ api/sudamaseva-create-subscription.php [L,QSA]

# api/sudamaseva/verify-payment → api/sudamaseva-verify-payment.php
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME} !-f
RewriteRule ^api/sudamaseva/verify-payment/?$ api/sudamaseva-verify-payment.php [L,QSA]

# api/sudamaseva/webhook → api/sudamaseva-webhook.php
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME} !-f
RewriteRule ^api/sudamaseva/webhook/?$ api/sudamaseva-webhook.php [L,QSA]

# api/sudamaseva/lookup → api/sudamaseva-lookup.php
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME} !-f
RewriteRule ^api/sudamaseva/lookup/?$ api/sudamaseva-lookup.php [L,QSA]

# api/sudamaseva/create-order → api/sudamaseva-create-order.php
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME} !-f
RewriteRule ^api/sudamaseva/create-order/?$ api/sudamaseva-create-order.php [L,QSA]

# api/sudamaseva/verify-order → api/sudamaseva-verify-order.php
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME} !-f
RewriteRule ^api/sudamaseva/verify-order/?$ api/sudamaseva-verify-order.php [L,QSA]

# api/sudamaseva/enroll → api/sudamaseva-enroll.php
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME} !-f
RewriteRule ^api/sudamaseva/enroll/?$ api/sudamaseva-enroll.php [L,QSA]

# api/sudamaseva/record-offline-payment → api/sudamaseva-record-offline-payment.php
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME} !-f
RewriteRule ^api/sudamaseva/record-offline-payment/?$ api/sudamaseva-record-offline-payment.php [L,QSA]

# ============================================
# Sudamaseva Module — Public Page Rewrites
# ============================================

# Must come BEFORE the generic rewrite to avoid matching sudamaseva.php
# sudamaseva/lookup → modules/Sudamaseva/content/lookup.php
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME} !-f
RewriteRule ^sudamaseva/lookup/?$ sudamaseva/lookup.php [L,QSA]

# sudamaseva/dashboard → modules/Sudamaseva/content/dashboard.php
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME} !-f
RewriteRule ^sudamaseva/dashboard/?$ sudamaseva/dashboard.php [L,QSA]

# ============================================
# Festival Detail Pages (SEO-friendly URLs)
# ============================================
# /festivals/grand-festivals/janmashtami/ → detail.php?slug=janmashtami
# Actual files (e.g. festivals/grand-festivals/janmashtami.php) take priority via !-f check
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME} !-f
RewriteRule ^festivals/grand-festivals/([^/]+)/?$ festivals/detail.php?slug=$1 [L,QSA]

RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME} !-f
RewriteRule ^festivals/ekadashi/([^/]+)/?$ festivals/detail.php?slug=$1 [L,QSA]

RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME} !-f
RewriteRule ^festivals/appearance/([^/]+)/?$ festivals/detail.php?slug=$1 [L,QSA]

RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME} !-f
RewriteRule ^festivals/disappearance/([^/]+)/?$ festivals/detail.php?slug=$1 [L,QSA]

RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME} !-f
RewriteRule ^festivals/events/([^/]+)/?$ festivals/detail.php?slug=$1 [L,QSA]

# ============================================
# Generic Rewrite: /page → /page.php
# ============================================
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.php -f
RewriteRule ^(.+?)/?$ $1.php [L]
</IfModule>

# ============================================
# Custom Error Pages
# ============================================
ErrorDocument 404 /404.php

# Fallback rewrite: if no file matches, route to 404.php
# (catches subdirectory installs where ErrorDocument path may not resolve)
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_URI} !^/(404\.php|assets/|favicon\.ico|robots\.txt|sitemap\.xml)
RewriteRule . 404.php [L]

# ============================================
# Browser Caching (Expires Headers)
# ============================================
<IfModule mod_expires.c>
  ExpiresActive On
  
  # Default: 1 month
  ExpiresDefault "access plus 1 month"
  
  # HTML, XML, PHP: 0 seconds (no cache for dynamic content — controlled by app)
  ExpiresByType text/html "access plus 0 seconds"
  ExpiresByType application/xhtml+xml "access plus 0 seconds"
  ExpiresByType application/xml "access plus 0 seconds"
  
  # CSS & JavaScript: 1 year (fingerprinted by version/contents)
  ExpiresByType text/css "access plus 1 year"
  ExpiresByType application/javascript "access plus 1 year"
  ExpiresByType application/x-javascript "access plus 1 year"
  
  # Fonts: 1 year
  ExpiresByType font/ttf "access plus 1 year"
  ExpiresByType font/otf "access plus 1 year"
  ExpiresByType font/woff "access plus 1 year"
  ExpiresByType font/woff2 "access plus 1 year"
  ExpiresByType application/font-woff "access plus 1 year"
  
  # Images: 1 year
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/gif "access plus 1 year"
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType image/x-icon "access plus 1 year"
  
  # PDFs & documents: 1 month
  ExpiresByType application/pdf "access plus 1 month"
</IfModule>

# ============================================
# Gzip Compression (mod_deflate)
# ============================================
<IfModule mod_deflate.c>
  # Enable compression
  AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript
  AddOutputFilterByType DEFLATE application/xml application/xhtml+xml application/rss+xml
  AddOutputFilterByType DEFLATE application/javascript application/x-javascript
  AddOutputFilterByType DEFLATE application/json application/ld+json
  AddOutputFilterByType DEFLATE font/ttf font/otf image/svg+xml
  
  # Exclude old browsers
  BrowserMatch ^Mozilla/4 gzip-only-text/html
  BrowserMatch ^Mozilla/4\.0[678] no-gzip
  BrowserMatch \bMSIE !no-gzip !gzip-only-text/html
  
  # Don't compress images (already compressed)
  SetEnvIfNoCase Request_URI \.(?:gif|jpe?g|png|webp)$ no-gzip dont-vary
</IfModule>

# ============================================
# Brotli Compression (fallback if mod_brotli available)
# ============================================
<IfModule mod_brotli.c>
  AddOutputFilterByType BROTLI text/html text/plain text/xml text/css text/javascript
  AddOutputFilterByType BROTLI application/xml application/xhtml+xml application/rss+xml
  AddOutputFilterByType BROTLI application/javascript application/x-javascript
  AddOutputFilterByType BROTLI application/json application/ld+json
</IfModule>
