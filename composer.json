{
    "name": "iskcon/isjm-website",
    "description": "ISKCON The Palace Temple of Lord Jagannath, Seshadripuram - Official Website",
    "type": "project",
    "require": {
        "vlucas/phpdotenv": "^5.6"
    },
    "autoload": {
        "psr-4": {
            "Isjm\\": "modules/Kernel/src/",
            "Isjm\\Modules\\": "modules/"
        },
        "files": [
            "includes/db.php",
            "includes/donation-helpers.php"
        ]
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true
    },
    "autoload-dev": {
        "psr-4": {
            "Isjm\\Tests\\": "tests/"
        }
    },
    "require-dev": {
        "phpunit/phpunit": "^12.5"
    }
}
